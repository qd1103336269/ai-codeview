{
  "name": "ai-codeview",
  "version": "0.3.0",
  "description": "面向中文用户的 DeepSeek AI 代码审查 CLI。",
  "type": "module",
  "keywords": [
    "ai",
    "code-review",
    "cli",
    "deepseek",
    "git",
    "typescript"
  ],
  "bin": {
    "ai-codeview": "dist/bin/ai-codeview.js",
    "ac": "dist/bin/ai-codeview.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/bin/ai-codeview.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.1",
    "cosmiconfig": "^9.0.0",
    "execa": "^9.6.0",
    "ignore": "^7.0.5",
    "openai": "^6.9.1",
    "ora": "^9.0.0",
    "p-limit": "^7.1.1",
    "p-retry": "^7.1.0",
    "parse-diff": "^0.11.1",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "nock": "^14.0.0",
    "prettier": "^3.0.0",
    "strip-ansi": "^7.1.0",
    "tempy": "^3.1.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.4"
  }
}
